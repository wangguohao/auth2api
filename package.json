{
  "name": "auth2api",
  "version": "1.0.0",
  "description": "Lightweight Claude OAuth to OpenAI-compatible API proxy",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "login": "tsx src/index.ts --login",
    "auth:error-summary": "tsx scripts/auth-errors.ts summary",
    "auth:error-trace": "tsx scripts/auth-errors.ts trace",
    "obs:report": "tsx scripts/observability.ts report",
    "obs:slow": "tsx scripts/observability.ts slow",
    "obs:trace": "tsx scripts/observability.ts trace",
    "obs:explain": "tsx scripts/observability.ts explain",
    "test": "tsx --test tests/*.test.ts",
    "test:smoke": "tsx --test tests/smoke.test.ts",
    "prettier": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "deploy:node20": "sudo bash scripts/install-node20.sh",
    "deploy:clone-install": "sudo bash scripts/clone-auth2api-install.sh",
    "deploy:nginx": "sudo bash scripts/install-nginx-domain.sh",
    "deploy:mihomo": "sudo bash scripts/install-mihomo-systemd.sh",
    "deploy:mihomo-instance": "sudo bash scripts/mihomo-new-instance-from-yaml.sh"
  },
  "dependencies": {
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "undici": "^6.27.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
